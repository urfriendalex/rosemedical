NEXT_PUBLIC_SITE_URL=https://rosemedical.pl

# --- Sanity CMS ---------------------------------------------------------------
# Find the project ID at https://www.sanity.io/manage (or `npx sanity projects list`).
# Until this is set, the site renders from the bundled fallback content and the
# Studio at /studio has no real project behind it. See docs/SANITY_SETUP.md.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-02-19

# --- Contact form (Resend) ----------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL="Rose Medical <contact@rosemedical.pl>"
CONTACT_TO_EMAIL=office@rosemedical.pl
